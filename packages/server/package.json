{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "license": "Apache-2.0",
  "engines": {
    "node": "22.21.0",
    "yarn": ">=1.22.4",
    "npm": "please-use-yarn"
  },
  "scripts": {
    "consume-grants": "node src/scripts/consumeGrantModifications.js",
    "coverage": "nyc yarn test",
    "create_tenant": "node src/db/tenant_creation.js",
    "migrate_saved_searches": "node src/db/saved_search_migration.js",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "yarn db:migrate && knex seed:run",
    "debug": "nodemon --inspect=0.0.0.0:9229 src",
    "env": "export $(cat .env)",
    "generate-rules": "node src/scripts/generateRules.mjs",
    "import-arpa-dump": "node src/scripts/import_arpa_reporter_dump.js",
    "lint": "eslint '**/*.js'",
    "migrate:make": "knex migrate:make",
    "migrate:up": "knex migrate:up",
    "parse-output-templates": "node src/scripts/parseOutputTemplates.mjs",
    "pre-commit": "yarn lint",
    "send-debug-email": "node src/scripts/sendDebugEmail.js",
    "serve": "nodemon src",
    "start:dev": "nodemon src",
    "start": "node src",
    "test:agencyimport": "NODE_ENV=test SUPPRESS_EMAIL=true mocha --exit --bail --require __tests__/api/fixtures.js __tests__/db/agencyImporter._test_.js",
    "test:apis": "NODE_ENV=test SUPPRESS_EMAIL=true mocha --exit --bail --require __tests__/api/fixtures.js __tests__/api/*.test.js",
    "test:arpa": "NODE_ENV=test __tests__/run_arpa_reporter_tests.sh",
    "test:db": "NODE_ENV=test mocha --timeout 10000 __tests__/db/*.test.js",
    "test:email": "NODE_ENV=test mocha __tests__/email/*.test.js",
    "test:lib": "NODE_ENV=test mocha  --file __tests__/lib/test-global-setup.js __tests__/lib/*.test.js",
    "test:scripts": "NODE_ENV=test mocha __tests__/scripts/*.test.js",
    "test:userimport": "NODE_ENV=test SUPPRESS_EMAIL=true mocha --exit --bail --require __tests__/api/fixtures.js __tests__/db/userImporter._test_.js",
    "test": "yarn test:apis && yarn test:arpa && yarn test:db && yarn test:userimport && yarn test:agencyimport && yarn test:email && yarn test:lib && yarn test:scripts",
    "start:arpa-audit-worker": "node src/scripts/arpaAuditReport.js",
    "debug:arpa-audit-worker": "nodemon --inspect=0.0.0.0:9229 src/scripts/arpaAuditReport.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.312.0",
    "@aws-sdk/client-ses": "^3.312.0",
    "@aws-sdk/client-sqs": "^3.345.0",
    "@aws-sdk/rds-signer": "^3.315.0",
    "@aws-sdk/s3-request-presigner": "^3.312.0",
    "adm-zip": "0.5.9",
    "async-batch": "1.1.2",
    "body-parser": "^1.20.0",
    "bunyan": "^1.8.15",
    "connect-history-api-fallback": "^1.6.0",
    "cookie-parser": "^1.4.5",
    "cron": "^4.4.0",
    "csv-stringify": "^6.0.5",
    "dd-trace": "^6.1.0",
    "docx": "^9.7.1",
    "dotenv": "^16.0.0",
    "email-validator": "^2.0.4",
    "express": "^5.2.1",
    "inquirer": "^8.2.2",
    "inquirer-search-list": "^1.2.6",
    "json-2-csv": "^5.5.8",
    "knex": "^3.3.0",
    "knex-paginate": "^3.2.0",
    "lodash": "^4.17.21",
    "lodash-checkit": "^2.4.1",
    "luxon": "^3.5.0",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "mustache": "^4.2.0",
    "nodemailer": "^9.0.3",
    "numeral": "^2.0.6",
    "pdf-lib": "^1.16.0",
    "pg": "^8.7.1",
    "pg-types": "4.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "ssf": "^0.11.2",
    "ts-invariant": "0.10.3",
    "uuid": "^14.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/compat": "^1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "chai": "^4.3.4",
    "chai-as-promised": "^7.1.1",
    "chalk": "^5.0.1",
    "cookie-signature": "^1.2.0",
    "eslint": "^10.6.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^16",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mkdirp": "^1.0.4",
    "mocha": "^11.7.6",
    "node-fetch": "^2.6.1",
    "nodemon": "^3.1.14",
    "nyc": "^15.1.0",
    "openapi-types": "^12.0.2",
    "pino-pretty": "^11.3.0",
    "prettier": "3.9.4",
    "rewire": "^6.0.0",
    "sinon": "^22.0.0",
    "supertest": "^6.2.3",
    "typescript": "^6.0.3"
  }
}
